{
  "name": "sparkpilot-x",
  "productName": "sparkpilot-x",
  "version": "1.0.0",
  "description": "A macOS-oriented Electron application",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "start": "electron-vite dev",
    "build": "electron-vite build",
    "clean": "rm -rf dist",
    "build:mac": "npm run clean && npm run build && electron-builder --mac",
    "typecheck": "tsc --noEmit",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "electron",
    "typescript",
    "macos",
    "vite",
    "trpc"
  ],
  "author": "simonxing",
  "license": "UNLICENSED",
