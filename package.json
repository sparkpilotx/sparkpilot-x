    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^37.2.5",
    "electron-builder": "^24.13.3",
    "electron-vite": "^4.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.11",
    "typescript": "5.8.3",
    "vite": "^7.0.6"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
